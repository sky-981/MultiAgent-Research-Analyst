# Copy this to .env (gitignored) and fill in real values.

# --- LLM (LiteLLM picks provider from model string) ---
# Gemini free se start recommended (agents bahut calls karte = cost).
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gemini/gemini-1.5-flash

# --- Web search ---
TAVILY_API_KEY=

# --- Observability (Langfuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- App ---
APP_ENV=local
